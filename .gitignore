# Root-level .gitignore — catches anything missed by sub-folder .gitignore files

# ===========================
# Dependencies
# ===========================
node_modules/

# ===========================
# Environment Variables (NEVER commit real credentials)
# ===========================
.env
.env.local
.env.development
.env.production
.env.test
.env.*.local

# ===========================
# Build output
# ===========================
dist/
build/

# ===========================
# Logs
# ===========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===========================
# OS generated files
# ===========================
.DS_Store
Thumbs.db
desktop.ini

# ===========================
# Editor directories
# ===========================
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ===========================
# Temporary files
# ===========================
tmp/
temp/
*.tmp
